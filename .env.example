# SenseArrival environment configuration
# Copy to .env and fill in your API keys

# --- LLM Backend selector ---
# Options: claude | ollama | replay
# OFFLINE_MODE=true is a shortcut alias for BACKEND=replay
BACKEND=claude
# OFFLINE_MODE=true

# --- Anthropic (required for BACKEND=claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs (required for live TTS/STT) ---
ELEVENLABS_API_KEY=...

# --- Ollama (required for BACKEND=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
